{
  "name": "web",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "NODE_ENV=production vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production bun run db:migrate && NODE_ENV=production node --env-file-if-exists=.env .output/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/lib/db/migrate.ts",
    "auth:generate": "bunx @better-auth/cli@latest generate --output src/lib/db/auth-schema.ts -y"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@electric-sql/pglite": "^0.4.3",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.16",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "latest",
    "block-rate": "workspace:*",
    "block-rate-server": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "nitro": "npm:nitro-nightly@latest",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.10.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "4"
  },
  "devDependencies": {
    "@better-auth/cli": "latest",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.28.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
