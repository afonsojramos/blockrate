# Do NOT set NODE_ENV in this file. Vite reads .env at build time and a
# hardcoded NODE_ENV=development would compile a dev bundle on `vite build`.
# Mode is determined by the script you run: `bun run dev` (development)
# vs `bun run start` (production, set automatically by the script).

# Local dev: pglite uses an in-process embedded postgres, zero setup.
# Production (Railway): swap for a real postgres:// URL via Railway's
# managed Postgres addon. SSL is auto-required when NODE_ENV=production.
DATABASE_URL=pglite://./.local/blockrate.db

# generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-or-more-character-secret

BETTER_AUTH_URL=http://localhost:3000

# ─── Phase 4 ────────────────────────────────────────────────────────────
# Bearer for /api/internal/retention. Required in production (the endpoint
# returns 503 if unset). Generate with the same openssl command.
# CRON_SECRET=replace-me-with-32-or-more-character-secret

# ─── Phase 5 ────────────────────────────────────────────────────────────
# All optional locally. dev keeps using console.log for magic links and
# hides OAuth buttons when these are unset.

# Resend transactional email — used for magic-link delivery in production.
# Get an API key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=blockrate <magic@blockrate.app>

# Google OAuth — provision at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $BETTER_AUTH_URL/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth — provision at https://github.com/settings/developers
# Authorization callback URL: $BETTER_AUTH_URL/api/auth/callback/github
# Required scope: user:email (for email_not_found errors during signup)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Stripe billing ─────────────────────────────────────────────────────
# All optional locally. Billing features hidden when STRIPE_SECRET_KEY is unset.
# Get keys at https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Create products + prices via: stripe products create / stripe prices create
# STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRO_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_TEAM_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_TEAM_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ─── Client (VITE_*) — exposed to the browser ───────────────────────────
# Public api key for dogfooding block-rate on blockrate.app itself. Bootstrap
# a key in production via the dashboard, then set this env var. When unset,
# the dogfood hook is a no-op.
# VITE_BLOCKRATE_PUBLIC_KEY=br_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
