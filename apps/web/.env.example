# Template for apps/web/.env. Copy to .env and fill in what you need;
# every block below is optional unless noted.
#
# Do NOT set NODE_ENV here. Vite reads .env at build time, and a hardcoded
# NODE_ENV=development would compile a dev bundle on `vite build`. Mode is
# determined by the script you run: `bun run dev` (development) vs
# `bun run start` (production — NODE_ENV is set automatically).

# ─── Core (required for boot) ──────────────────────────────────────────
# Generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-or-more-character-secret

# ─── Database ──────────────────────────────────────────────────────────
# Local dev uses pglite (in-process embedded Postgres, zero setup). For
# production, swap for a postgres:// URL (e.g. Railway managed Postgres).
# SSL is auto-required when NODE_ENV=production.
DATABASE_URL=pglite://./.local/blockrate.db

# ─── Public URLs ───────────────────────────────────────────────────────
# Origin used by Better Auth for redirects / trusted origins and by the
# /api/block-rate dogfood route (via BLOCKRATE_SELF_URL fallback).
BETTER_AUTH_URL=http://localhost:3000

# Public canonical origin for SEO (canonical link, og:url, sitemap.xml,
# robots.txt). VITE_-prefixed so the seo() helper can read it from
# import.meta.env on both server and client without hydration mismatches.
# Leave unset in local dev to omit canonical tags entirely — a missing
# canonical beats a wrong one.
VITE_SITE_URL=https://blockrate.app

# ─── Retention job ─────────────────────────────────────────────────────
# Bearer for /api/internal/retention. Required in production (the
# endpoint returns 503 if unset). Generate with openssl as above.
# CRON_SECRET=replace-me-with-32-or-more-character-secret

# ─── Email (magic links) ───────────────────────────────────────────────
# Resend transactional email — used for magic-link delivery in production.
# When unset in dev, sendMagicLink logs the link to the terminal instead.
# Get an API key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=blockrate <noreply@blockrate.app>

# ─── OAuth providers ───────────────────────────────────────────────────
# Each provider's buttons are hidden from /login and /signup when its
# credentials are unset.

# Google — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $BETTER_AUTH_URL/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
# Authorization callback URL: $BETTER_AUTH_URL/api/auth/callback/github
# Required scope: user:email (for email_not_found errors during signup)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Stripe billing ────────────────────────────────────────────────────
# Billing features (pricing upgrades, checkout, customer portal) are
# hidden when STRIPE_SECRET_KEY is unset. Get keys at
# https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Create products + prices via: stripe products create / stripe prices create
# STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRO_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_TEAM_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_TEAM_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ─── Dogfood ───────────────────────────────────────────────────────────
# Server-side API key for dogfooding blockrate on blockrate.app itself.
# Bootstrap a key in production via the dashboard, then set this env
# var. When unset, the /api/block-rate forward route returns 204 without
# forwarding — safe default for local dev. Never expose this key to the
# browser; the forward helper keeps it server-side automatically.
# BLOCKRATE_API_KEY=br_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
